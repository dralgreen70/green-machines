generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Swimmer {
  id              Int        @id @default(autoincrement())
  firstName       String
  lastName        String
  usaSwimmingId   String?
  times           SwimTime[]

  @@unique([firstName, lastName])
}

model SwimTime {
  id            Int         @id @default(autoincrement())
  swimmerId     Int
  eventName     String
  timeInSeconds Float
  date          DateTime
  meetName      String
  course        String
  swimmer       Swimmer     @relation(fields: [swimmerId], references: [id])
  splits        SwimSplit[]

  @@unique([swimmerId, eventName, date, meetName])
}

model SwimSplit {
  id                  Int      @id @default(autoincrement())
  swimTimeId          Int
  distance            Int
  splitTime           Float
  cumulativeSplitTime Float
  swimTime            SwimTime @relation(fields: [swimTimeId], references: [id], onDelete: Cascade)

  @@index([swimTimeId])
}

model SwimmerRequest {
  id              Int      @id @default(autoincrement())
  firstName       String
  lastName        String
  usaSwimmingId   String?
  requestedAt     DateTime @default(now())
  status          String   @default("pending")
}
